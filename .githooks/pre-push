#!/usr/bin/env bash
# Runs the trimmi-base tests before EVERY push. Activated per-clone with:
#     git config core.hooksPath .githooks
# (one-time; see RELEASING.md → "Tests run automatically before every push").
#
# Do not routinely bypass with `git push --no-verify`: a broken mount or login
# regression silently breaks Claude/aider/gh in every consuming repo.
set -euo pipefail
repo="$(git rev-parse --show-toplevel)"
cd "$repo"

echo "[pre-push] 1/3 shell syntax (install.sh)…"
bash -n src/trimmi-base/install.sh

echo "[pre-push] 2/3 feature metadata (all 4 mounts + containerEnv)…"
bash test/validate-metadata.sh

echo "[pre-push] 3/3 feature test suite in a container (login + mounts)…"
if ! command -v devcontainer >/dev/null 2>&1; then
  echo "[pre-push] ERROR: 'devcontainer' CLI not found — cannot run the container tests."
  echo "           Install it:  npm install -g @devcontainers/cli   (needs Docker running)."
  exit 1
fi
devcontainer features test \
  --project-folder "$repo" \
  --features trimmi-base \
  --base-image mcr.microsoft.com/devcontainers/base:ubuntu-24.04 \
  --skip-scenarios

echo "[pre-push] ✅ all tests passed — pushing."
